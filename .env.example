# Скопируйте в .env и при необходимости поправьте значения.
PORT=3000

# MongoDB и Redis поднимаются локально (без Docker по условию задания).
MONGO_URI=mongodb://localhost:27017/payments
REDIS_URL=redis://localhost:6379

# Общий секрет для проверки HMAC-подписи входящих вебхуков (обязателен).
WEBHOOK_HMAC_SECRET=super-secret-change-me

# Окно допустимой «свежести» X-Timestamp, сек (защита от replay).
WEBHOOK_TIMESTAMP_TOLERANCE_SEC=300

# TTL хранения nonce; должен быть >= окна timestamp.
NONCE_TTL_SEC=600
